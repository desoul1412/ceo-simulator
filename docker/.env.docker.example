# CEO Simulator — Docker environment variables

# Database mode: 'supabase' (cloud) or 'postgres' (self-hosted)
DATABASE_MODE=supabase

# Supabase connection (required for DATABASE_MODE=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# LLM provider: 'anthropic', 'openrouter', or 'auto'
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter fallback (optional, used when LLM_PROVIDER=auto or openrouter)
OPENROUTER_API_KEY=

# PostgreSQL (used when DATABASE_MODE=postgres)
POSTGRES_PASSWORD=ceosim_dev_pass

# Sandbox mode: 'none', 'docker', or 'e2b'
SANDBOX_MODE=none

# Audit HMAC secret for proof chain
AUDIT_HMAC_SECRET=change-me-in-production
