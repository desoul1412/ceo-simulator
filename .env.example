# Frontend (Vite — VITE_ prefix required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: custom orchestrator URL (default: http://localhost:3001)
# VITE_ORCHESTRATOR_URL=http://localhost:3001

# ─── Server orchestrator (copy to server/.env) ──────────────────────────────

# Required: Supabase connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Server port (default: 3001)
# PORT=3001

# Optional: Brain filesystem mirror (default: false — PG is primary)
# BRAIN_SYNC_ENABLED=false

# Optional: Embedding provider for semantic memory search
# Supports any OpenAI-compatible embedding API (OpenAI, OpenRouter, Ollama)
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMS=1536
