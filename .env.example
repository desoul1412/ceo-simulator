# Frontend (Vite — VITE_ prefix required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: custom orchestrator URL (default: http://localhost:3001)
# VITE_ORCHESTRATOR_URL=http://localhost:3001

# Optional: orchestrator shared secret (must match ORCHESTRATOR_SECRET on server)
# VITE_ORCHESTRATOR_SECRET=your-secret-here

# ─── Server orchestrator (copy to server/.env) ──────────────────────────────

# Required: Supabase connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Server port (default: 3001)
# PORT=3001

# Optional: Brain filesystem mirror (default: false — PG is primary)
# BRAIN_SYNC_ENABLED=false

# Optional: Shared secret for orchestrator API auth.
# When set, the frontend must send X-Orchestrator-Secret: <value> on every request.
# Generate one with: openssl rand -hex 32
# ORCHESTRATOR_SECRET=your-secret-here

# Optional: Embedding provider for semantic memory search (pgvector ANN similarity)
# Recommended: Ollama local (free, no key needed)
#   1. Install Ollama: https://ollama.com
#   2. Run: ollama pull nomic-embed-text
EMBEDDING_API_URL=http://localhost:11434/v1/embeddings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMS=768
# EMBEDDING_API_KEY=   # not needed for Ollama; set for OpenAI/Voyage/etc.
#
# Alternatives:
#   OpenAI:   EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
#             EMBEDDING_API_KEY=sk-...  EMBEDDING_MODEL=text-embedding-3-small  EMBEDDING_DIMS=1536
#   Voyage:   EMBEDDING_API_URL=https://api.voyageai.com/v1/embeddings
#             EMBEDDING_API_KEY=pa-...  EMBEDDING_MODEL=voyage-3-lite  EMBEDDING_DIMS=512
